{"stateRefs":{"comp-lm3cvpdf":{"experiments":{"$type":"ref","refPath":["exports","environment","experiments"]}},"comp-lm3cvp8r":{"experiments":{"$type":"ref","refPath":["exports","environment","experiments"]}}},"structure":{"components":{"comp-lm3cvpdf":{"componentType":"WRichText","pageId":"gca53"},"pageBackground_gca53":{"componentType":"PageBackground","pageId":"masterPage"},"gca53":{"components":["Containergca53"],"componentType":"Page","uiType":"TransparentPageSkin","pageId":"gca53"},"comp-lm3cvp8r":{"components":["comp-lm3cvpdf"],"componentType":"ClassicSection","pageId":"gca53"},"Containergca53":{"components":["comp-lm3cvp8r"],"componentType":"Group","pageId":"gca53"}},"features":["accessibilityBrowserZoom","clickHandlerRegistrar","components","domSelectors","environmentService","imagePlaceholder","mpaNavigation","navigationManager","pageAnchors","pageTransitions","renderer","reporter","scrollRestoration","scrollToAnchor","seo","windowScroll","wixEmbedsApi","componentsLoader"],"siteFeaturesConfigs":null},"props":{"render":{"compProps":{"comp-lm3cvpdf":{"html":"<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\"><span style=\"color:#8B0000;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:0em;\" class=\"wixui-rich-text__text\"><span style=\"font-style:italic;\" class=\"wixui-rich-text__text\"><span style=\"font-size:24px;\" class=\"wixui-rich-text__text\"><span style=\"font-family:pridi,serif;\" class=\"wixui-rich-text__text\">El Proyecto</span></span></span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\">&nbsp;</p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\"><span style=\"color:#8B0000;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:0em;\" class=\"wixui-rich-text__text\"><span style=\"font-style:italic;\" class=\"wixui-rich-text__text\"><span style=\"font-size:24px;\" class=\"wixui-rich-text__text\">Cuatro amigos, enamorados del mar, decidieron embarcarse en una aventura que les marcar&iacute;a para siempre. Con la esperanza y la emoci&oacute;n de los antiguos navegantes, se propusieron formar un equipo de regatas para participar en el circuito del levante espa&ntilde;ol. Este fue el comienzo de un viaje lleno de ilusi&oacute;n y experiencias inolvidables.</span></span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\">&nbsp;</p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\"><span style=\"color:#8B0000;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:0em;\" class=\"wixui-rich-text__text\"><span style=\"font-style:italic;\" class=\"wixui-rich-text__text\"><span style=\"font-size:24px;\" class=\"wixui-rich-text__text\">So&ntilde;aban con armar un velero que fuera a la vez una m&aacute;quina de regatas de alta competici&oacute;n y un lugar de encuentro donde compartir conocimientos y experiencias n&aacute;uticas. Quer&iacute;an en definitiva crear un espacio donde poder compartir su pasi&oacute;n por la navegaci&oacute;n con todas aquellas personas que se unieran al proyecto.</span></span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\"><span style=\"color:#8B0000;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:0em;\" class=\"wixui-rich-text__text\"><span style=\"font-style:italic;\" class=\"wixui-rich-text__text\"><span style=\"font-size:24px;\" class=\"wixui-rich-text__text\">​</span></span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\"><span style=\"color:#8B0000;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:0em;\" class=\"wixui-rich-text__text\"><span style=\"font-style:italic;\" class=\"wixui-rich-text__text\"><span style=\"font-size:24px;\" class=\"wixui-rich-text__text\">El&nbsp; sue&ntilde;o se hizo realidad cuando consiguieron adquirir un velero de regatas IMX 40, obra maestra de la ingenier&iacute;a naval, construida por el prestigioso astillero dan&eacute;s X-Yacht, al que bautizaron &quot;Fenicio&quot; en homenaje al inolvidable navegante murciano Manuel Ortiz &quot;El Ma&ntilde;o&quot;</span></span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\"><span style=\"color:#8B0000;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:0em;\" class=\"wixui-rich-text__text\"><span style=\"font-style:italic;\" class=\"wixui-rich-text__text\"><span style=\"font-size:24px;\" class=\"wixui-rich-text__text\">​</span></span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\"><span style=\"color:#8B0000;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:0em;\" class=\"wixui-rich-text__text\"><span style=\"font-style:italic;\" class=\"wixui-rich-text__text\"><span style=\"font-size:24px;\" class=\"wixui-rich-text__text\">Desde entonces han participado en numerosos regatas locales, como el Trofeo Regularidad del Club N&aacute;utico Villa de San Pedro &nbsp;y tambi&eacute;n en regatas de altura, como La Ruta de la Sal. Su victoria en el Campeonato Regional de Crucero de la Regi&oacute;n de Murcia en 2022 fue un aut&eacute;ntico hito en este viaje.​​​​​​​​</span></span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\"><span style=\"color:#8B0000;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:0em;\" class=\"wixui-rich-text__text\"><span style=\"font-style:italic;\" class=\"wixui-rich-text__text\"><span style=\"font-size:24px;\" class=\"wixui-rich-text__text\">​</span></span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\"><span style=\"color:#8B0000;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:0em;\" class=\"wixui-rich-text__text\"><span style=\"font-style:italic;\" class=\"wixui-rich-text__text\"><span style=\"font-size:24px;\" class=\"wixui-rich-text__text\">El apartado &quot;Libro de Bit&aacute;cora&quot; de esta p&aacute;gina web, ser&aacute; el lugar donde compartiremos con todos vosotros esta aventura y cada entrada ser&aacute; un nuevo cap&iacute;tulo del viaje, lleno de desaf&iacute;os, logros y tambi&eacute;n, porqu&eacute; no decirlo, alg&uacute;n que otro fracaso..</span></span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\"><span style=\"color:#8B0000;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:0em;\" class=\"wixui-rich-text__text\"><span style=\"font-style:italic;\" class=\"wixui-rich-text__text\"><span style=\"font-size:24px;\" class=\"wixui-rich-text__text\">​</span></span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\"><span style=\"color:#8B0000;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:0em;\" class=\"wixui-rich-text__text\"><span style=\"font-style:italic;\" class=\"wixui-rich-text__text\"><span style=\"font-size:24px;\" class=\"wixui-rich-text__text\">La historia de estos cuatro amigos y el equipo que han conformado, es en definitiva un relato de amor a la mar y del esp&iacute;ritu de aventura que se encuentra en el coraz&oacute;n de todo navegante.</span></span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\">&nbsp;</p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:24px; line-height:normal;\"><span style=\"color:#8B0000;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:0em;\" class=\"wixui-rich-text__text\"><span style=\"font-style:italic;\" class=\"wixui-rich-text__text\"><span style=\"font-size:24px;\" class=\"wixui-rich-text__text\">&iexcl;Buena Proa, Fenicio!</span></span></span></span></span></p>","skin":"WRichTextThemeSkin","isQaMode":false,"fullNameCompType":"wysiwyg.viewer.components.WRichText"},"pageBackground_gca53":{"fillLayers":{"containerId":"pageBackground_gca53","hasBgFullscreenScrollEffect":false,"shouldRenderUnderlay":true,"image":{"uri":"344230_91e46388e8e9415e857f7c052fa49281~mv2.jpg","width":1187,"height":1067,"title":"Fenicio01.jpg","containerId":"pageBackground_gca53","hasBgScrollEffect":"","bgEffectName":"","alignType":"center","displayMode":"fill","link":{},"encoding":"AVIF","containerWidth":1920,"containerHeight":1920},"shouldPadMedia":false,"hasCanvasAnimation":false},"isMediaPositionOverride":false,"mediaHeightOverrideType":""},"gca53":{"className":"theme-vars"},"comp-lm3cvp8r":{"meshProps":{"wedges":[],"rotatedComponents":[],"fixedComponents":[]},"fillLayers":{"containerId":"comp-lm3cvp8r","hasBgFullscreenScrollEffect":false,"shouldRenderUnderlay":true,"image":{"uri":"344230_800f935419754a7a813f877fde29fa5a~mv2.jpg","alt":"IMG-20250224-WA0002.jpg","width":1600,"height":1200,"title":"IMG-20250224-WA0002