@import url(https://fonts.googleapis.com/css?family=Open+Sans:600,400,300|Poppins:400,600);
#container {
    background-color: #FFF;
    padding-bottom: 64px;
}

a {
    color: #006BB5;
    text-shadow: none;
}

a:hover { text-shadow: none; }


.newslisting-tool a{text-decoration: underline; font-size: 13px; padding-top: 10px;}


.logo-container .logo {padding: 15px 0;}

header { background: url("/images/default/globalsolutions/cab-bg.jpg") no-repeat scroll right top #FFF;
margin-bottom: 40px; padding-bottom: 0px; }

header > .row{ height:190px;}

header .links a {color:#0E76BC; text-decoration: underline;}
header .links a:hover {color:#0E76BC; text-decoration: none;}

body { font-family: 'Open Sans', sans-serif; color: #666;}

#footer { box-shadow: 0 0; border-top: solid 4px  #0E76BC; padding: 16px 0 20px;  background: #FFF;}
#footer .submenu-container a {color:#283891; text-decoration: underline;}
#footer .contact-txt p {color: #84888B;}
#footer .contact-txt p a {
    color: #4C50AD;
}


.menu-content {background: #0E76BC; border: none; box-shadow: none;}
.nav-bar .nav-bar > li {font-family: 'Poppins', sans-serif; font-weight: 600; text-transform:uppercase; background:none;}
.nav-bar > li > a:first-child { padding: 1px 20px; font-size: 16px;}
.nav-bar .nav-bar > li a { color: #FFF; text-decoration:none; }
.nav-bar .nav-bar > li.active {background:#25AAE1;}
.nav-bar .nav-bar > li.active > a:hover {color:#0E76BC;}
.nav-bar > li.active > a {color:#FFF;}
.nav-bar > li > a:hover {color:#66D1FF;}
.nav-bar > li:last-child{border-right:0; box-shadow:none;}



.nav-bar > li.nav-social { float: right; }
.nav-bar > li.nav-social > a:first-child { display: inline-block; width:27px; height:24px; margin-top:7px}
.nav-bar > li.nav-social > a {
	padding: 0 0 0 4px; background: url(/images/default/globalsolutions/social-icons.png) 100px 100px no-repeat;	
}
.nav-bar > li.nav-social > a > span{display:none;}
@media only screen and (max-width: 767px) {
header > .row{ height:120px;}
  .nav-bar > li.nav-social { float: none; }
  .nav-bar .nav-bar > li > a:first-child { padding: 0 0 0 4px; }
}


h1 { color: #283891; font-family: 'Open Sans', sans-serif; }
h2 {  color: #283891; font-family: 'Open Sans', sans-serif; font-weight: 600;  font-size: 17px; margin-top: 0px; }
h2 a {  color: #0E76BC; font-family: 'Open Sans', sans-serif; font-weight: 600;  font-size: 21px; margin-top: 0px; }
h3, h3.title, .item.news h3.title, h3 a, .eventinfo.news.title-bar.sep h2.title {  color: #283891; font-family: 'Open Sans', sans-serif; font-weight: 600;  font-size: 21px; margin-bottom: 12px;}
h2.title {  color: #666 !important; font-family: 'Poppins', sans-serif; font-weight: 600;  font-size: 17px; margin-bottom: 10px;}
.title-bar h2 {  color: #283891; text-transform: uppercase;}

.racelisting-item h3 a { font-size: 17px;}

.racelisting-item, .resultslisting-item, .document {
   border-width: 1px;
   border-color: #ddd;
   background-color: #FFF;
 border-radius: 0px;
}

.resultslisting-item h4 a {
    color: #283891;
}

.newslisting-item h3.listtitle a{  color: #283891;}

.nav-bar-right { line-height: 1; min-height: auto; margin-bottom: 0;}


#linkReturn, .theme, .theme-plain {
    font-family: 'Poppins', sans-serif;
    text-transform:uppercase;
    font-weight: 600;
    background: #0E76BC;
    padding: 10px 10px 10px;
    border: medium none;
    border-radius: 0;
    box-shadow: none;
    color: #FFF;
    margin-bottom: 10px;
    vertical-align: baseline;
}
.theme-plain.on {
background: #022740;
}
  .theme:hover, .theme-plain:hover {
    text-decoration: none;
    background-color: #25AAE1;
}
  .theme:active, .theme-plain:active, .theme:focus, .theme-plain:focus {
    background-color: #25AAE1;
    position: relative;
    top: 1px;
    box-shadow: none;
}


.theme-anchor {
color: #283891;
}

  .theme-anchor:hover {
    background: transparent;
    text-shadow: none;
    color: #0E76BC;
  }

.button span.r, .button-bevel span.r, span.bt.r {padding: 4px 0 0 10px;float: right;text-transform: lowercase;} 



.race-title {border-bottom: none }

.search .ico-sailclass { width: 40px; height: 40px; }
.ico-sailclass { background-image: url(/images/default/globalsolutions/ico-clases.png); }

.race-item .logo { border: 0px none; }

.listdate, .listdate span { color: #006BB5; padding-bottom: 6px;}

#searchsend{background: none repeat scroll 0 0 #98A2B3; border-radius: 0; box-shadow: none; margin-left: 10px; padding-top: 3px; height: 29px;}
#searchsend:hover{
    text-decoration: none;
    background-color: #0E76BC;
}


#searchtext{height: 29px; color:#777777; font-size: 14px;}

.number-cont{color:#FFFFFF; font-size:21px; font-weight:400;}
.number-exp{color:#FFFFFF; font-size:21px; font-weight:400;}
.dates{color:#FFFFFF; font-size:12px; }
.ico-expand-closed .expand{background: url(/images/default/arrow-expand.png) no-repeat -21px 0; display:block; width:21px; height:21px;}
.ico-expand-opened .cont{background: url(/images/default/arrow-expand.png) no-repeat 0 0; display:block; width:21px; height:21px;}


dl.tabs dd.active { border-top: 3px solid #0E76BC; margin-top: -3px; }
dl.tabs dd.active a {border-color: #999; color: #283891; background: #fff;}
dl.tabs.months dd.active a {color: #283891;}
dl.tabs dd a, dl.tabs.months dd a {color: #888; font-size: 13px;}
dl.tabs {border-bottom: 1px solid #999;}


#myTable .tdcont{ background-color: #7895AD; color:;}
#myTable .thcont{ background-color: #7895AD;}


#myTable .tdexp{ background-color: #1493D6;}
#myTable .thexp{ background-color: #1493D6;}

table.result td { border: 1px solid #ddd;}
table.result th.header, table.result th.header.headerSortUp, table.result th.header.headerSortDown { background-color: #697E94; }

.race-item .sailclass-icons { float: none; }
.race-item .ico-sailclass {float: none; display: inline-block;}
.racelisting-item .sailclass-icons { float: none; text-align: right;}
.racelisting-item .ico-sailclass {float: none; display: inline-block;}

.right-column .item-emphText { font-size: 17px; line-height: 1.5; color: #888; background-color: #eee;padding: 25px; font-style: inherit;}

.title-bar.sep.news {display: table;width: 100%;}
.title-bar.sep { border-bottom: 3px solid #0E76BC; margin-bottom: 12px; }

.header-results-all { background-color: #697E94; border-radius: 0; margin: 0 0 40px; width: auto;}
table.result td.position { background-color: #eee; }

.race-info h3 { color: #FFF; font-size: 25px; }
.header-results-all .race-info .listdate, .header-results-all .race-info .listdate span { color: #FFF; }
.item-summary p {color: #6D84B4; font-size: 18px;}
header .links-container .links { padding: 4px;}

.results-list-item-title { border-bottom: none; }


fieldset { border: 1px solid #ddd; }
#pay-block { background-color: #eee; }


ul.inscription-steps li {font-weight: 400; color: #999;}
ul.inscription-steps li.on { opacity: 1; color: #052E66;}

.search .ico-sailclass { width: 40px; height: 40px; }
.ico-sailclass { background-image: url(/images/default/rcrsr/ico-classes.png); }
/* CUSTOM SVG ICONS */
.ico-sailclass, .search .ico-sailclass { background-image: none; }
a.ico-sailclass { cursor: pointer; }
.ico-sailclass .class-icon { display: inline-block; }

.ico-sailclass .class-icon #rectangle { fill: #FFF; stroke: #EEE; }
.ico-sailclass .class-icon path:not(#rectangle) { fill: #97A2B4; }

.ico-sailclass.off .class-icon #rectangle { fill: #0077BE; stroke: #0077BE; }
.ico-sailclass.off .class-icon path:not(#rectangle) { fill: #FFF; }

.ico-sailclass.on .class-icon #rectangle,
a.ico-sailclass:hover .class-icon #rectangle { fill: #00ACE2; stroke: #00ACE2; }
.ico-sailclass.on .class-icon path:not(#rectangle),
a.ico-sailclass:hover .class-icon path:not(#rectangle) { fill: #FFF; }
/* END OF CUSTOM SVG ICONS */

/* MENU RESPONSIVE */


.bt-collapse-container { display: none; }

@media (max-width: 768px) {
	header { background-size: auto; background-position: top center;  }
	.dynamic-slide { background-size: auto; background-position: top center; }
	.menu-content .nav-bar { height: auto; }
	.bt-collapse-container { display: block;  padding: 10px 10px 0; }
	.bt-collapse { cursor: pointer; background: #FFF; display: inline-block; padding: 10px; border-radius: 6px; margin-bottom: 10px; }
	.menu-content { padding-bottom: 0; height: auto;}
	.menu-content .submenu-container > .nav-bar > li { width: 100% !important; }
	.menu-content .submenu-container { max-height: 0; transition: all ease 0.3s; overflow: hidden; }
	.menu-content .submenu-container.active { max-height: 500px; }
	.nav-bar .nav-bar > li { border: none; border-bottom: 1px solid rgba(255,255,255,0.2); text-align: center; padding: 0; }
	.nav-bar .nav-bar > li:first-child { border-top: 1px solid rgba(255,255,255,0.2); }
	
	.menu-content { margin: 0 !important; padding-bottom: 0 !important; }
	.menu-content .sub-nav-bar { overflow: hidden; display: block; position: static; height: auto; background: rgba(0,0,0,0.1) !important; transition: all ease 0.3s; max-height: 0; }
	.menu-content .sub-nav-bar.active { max-height: 500px; }
	.menu-content .sub-nav-bar > li { float: none; }
	.menu-content .sub-nav-bar li a { text-transform: none; font-size: 13px; }

}



