/* MENU RESPONSIVE */

$(document).ready(function () {
	$('.menu-content > .row').prepend('<div class="sixteen columns text-right bt-collapse-container"><div class="bt-collapse"><i class="fa fa-bars"></i></div></div>');

	$('.bt-collapse').click(function() {
		$('.menu-content .submenu-container').toggleClass('active');
	});
	$('.nav-bar > li > a').click(function() {
		if($(this).parent().find('.sub-nav-bar').hasClass('active')) {
			$(this).parent().find('.sub-nav-bar').removeClass('active');
		} else {
			$('.sub-nav-bar').removeClass('active');
			$(this).parent().find('.sub-nav-bar').addClass('active');
		}
	});
});
    	//]]>
		</script>
