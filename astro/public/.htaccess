RewriteEngine On

# Raíz: servir home archivada (sin cadena de redirecciones Astro)
RewriteRule ^$ /raw/index.html [L]

# Sirve archivos/directorios existentes sin reescritura
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback a index.html para rutas limpias estáticas
RewriteRule ^(.+?)/?$ /$1/index.html [L]
