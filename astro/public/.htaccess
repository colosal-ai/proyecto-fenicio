RewriteEngine On

# ACME HTTP-01 (Let's Encrypt / Plesk): no reescribir; el token lo sirve el panel o httpdocs/.well-known/
RewriteRule ^\.well-known/ - [L]

# / sirve dist/index.html (copia de prepare en raíz; no rewrite interno a /raw/)

# Alias antiguo /blog/todos/ → /blog/ (una sola redirección 301)
RewriteRule ^blog/todos/?$ /blog/ [R=301,L]
RewriteRule ^blog/todos/page/([0-9]+)/?$ /blog/page/$1/ [R=301,L]

# Rutas Astro stub (/equipo/, /embarcacion/) → HTML Wix en raíz
RewriteRule ^equipo/?$ /equipo.html [R=301,L]
RewriteRule ^embarcacion/?$ /embarcación.html [R=301,L]

# Sirve archivos y directorios reales
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# URLs Wix: /equipo.html → /raw/equipo.html
RewriteCond %{DOCUMENT_ROOT}/raw/$1.html -f
RewriteRule ^(.+)\.html$ /raw/$1.html [L]

# Posts Wix: /post/slug.html → /post/slug/
RewriteRule ^post/(.+)\.html$ /post/$1/ [R=301,L]

# blog.html del mirror → /blog/
RewriteRule ^blog\.html$ /blog/ [R=301,L]

# Rutas Astro sin extensión: /blog/page/2 → index.html
RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{2,5}$ [NC]
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.+?)/?$ /$1/index.html [L]
