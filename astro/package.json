{
  "name": "fenicio-astro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:content": "node scripts/import-from-mirror.mjs",
    "vendorize:raw": "node scripts/vendorize-raw.mjs",
    "backup:post-images": "node scripts/backup-post-images.mjs --all",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "healthcheck:local": "bash scripts/healthcheck-local.sh",
    "pull:install": "bash scripts/pull-and-install.sh",
    "deploy:server": "bash scripts/deploy-on-server.sh",
    "deploy:plesk": "bash scripts/deploy-plesk.sh",
    "deploy:remote": "bash scripts/deploy-remote-ssh.sh",
    "deploy:full": "bash scripts/pull-and-deploy.sh",
    "prepare": "npm run sync:content && npm run vendorize:raw && npm run build"
  },
  "dependencies": {
    "astro": "^5.8.0"
  }
}
