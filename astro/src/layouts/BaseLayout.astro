---
import "../styles/global.css";
const { title = "Fenicio", showHeader = true } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    {showHeader && (
      <header class="site-header">
        <div class="site-header-inner">
          <a class="site-brand" href="/">Amigos del Fenicio</a>
          <nav class="site-nav" aria-label="Principal">
            <a href="/">El Proyecto</a>
            <a href="/equipo/">El Equipazo</a>
            <a href="/embarcacion/">La Máquina</a>
            <a href="/blog/">El Libro de Bitácora</a>
          </nav>
        </div>
      </header>
    )}
    <main class="container">
      <slot />
    </main>
  </body>
</html>
