---
import "../styles/global.css";

const { title = "Fenicio", showHeader = true } = Astro.props;
const canonicalHref = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;

/** Páginas Wix archivadas en raíz de dist/ (no los stubs /equipo/ ni /embarcacion/). */
const NAV = [
  { href: "/", label: "El Proyecto" },
  { href: "/equipo.html", label: "El Equipazo" },
  { href: "/embarcación.html", label: "La Máquina" },
  { href: "/blog/", label: "El Libro de Bitácora" }
];

function navIsCurrent(href: string, pathname: string) {
  if (href === "/") return pathname === "/" || pathname === "/index.html";
  if (href.endsWith(".html")) return pathname === href || pathname === `/raw${href}`;
  return pathname === href || pathname.startsWith(`${href.replace(/\/$/, "")}/`);
}
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {canonicalHref && <link rel="canonical" href={canonicalHref} />}
  </head>
  <body>
    {showHeader && (
      <header class="site-header">
        <div class="site-header-inner">
          <a class="site-brand" href="/">Amigos del Fenicio</a>
          <nav class="site-nav" aria-label="Principal">
            {NAV.map(({ href, label }) => (
              <a
                href={href}
                aria-current={navIsCurrent(href, Astro.url.pathname) ? "page" : undefined}
              >
                {label}
              </a>
            ))}
          </nav>
        </div>
      </header>
    )}
    <main class="container">
      <slot />
    </main>
  </body>
</html>
