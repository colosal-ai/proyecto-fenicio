---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import PostListPage from "../../../../components/PostListPage.astro";
import posts from "../../../../data/posts.json";

const POSTS_PER_PAGE = 5;
const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));

export function getStaticPaths() {
  const postsPerPage = 5;
  const pages = Math.max(1, Math.ceil(posts.length / postsPerPage));
  return Array.from({ length: pages - 1 }, (_, index) => {
    const page = index + 2;
    return { params: { page: String(page) } };
  });
}

const pageNumber = Number.parseInt(Astro.params.page || "2", 10);
const safePage = Number.isNaN(pageNumber) ? 2 : Math.min(Math.max(pageNumber, 2), totalPages);
const start = (safePage - 1) * POSTS_PER_PAGE;
const end = start + POSTS_PER_PAGE;
const pagePosts = posts.slice(start, end);
---
<BaseLayout title={`Fenicio - Blog (Todos, página ${safePage})`}>
  <PostListPage
    posts={pagePosts}
    totalPosts={posts.length}
    currentPage={safePage}
    totalPages={totalPages}
    basePath="/blog/todos/"
  />
</BaseLayout>
