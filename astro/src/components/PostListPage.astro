---
interface PostItem {
  slug: string;
  title: string;
  publishedAt?: string;
  thumbnailUrl?: string;
  excerpt?: string;
  youtubeUrl?: string;
}

interface Props {
  posts: PostItem[];
  totalPosts: number;
  currentPage: number;
  totalPages: number;
  basePath: string;
}

const { posts, currentPage, totalPages, basePath } = Astro.props as Props;
const normalizedBasePath = basePath.endsWith("/") ? basePath : `${basePath}/`;
const prevHref =
  currentPage <= 2 ? normalizedBasePath : `${normalizedBasePath}page/${currentPage - 1}/`;
const nextHref =
  currentPage < totalPages ? `${normalizedBasePath}page/${currentPage + 1}/` : "";
---
<section class="card blog-page">
  <h1>Las Noticias</h1>
  <div class="post-grid">
    {posts.map((post) => (
      <article class="post-card">
        {post.thumbnailUrl && (
          <div class="post-card-media">
            <a href={`/post/${post.slug}/`} class="post-thumb-link">
              <img class="post-thumb" src={post.thumbnailUrl} alt={post.title} loading="lazy" />
            </a>
          </div>
        )}
        <div class="post-card-body">
          <h2><a href={`/post/${post.slug}/`}>{post.title}</a></h2>
          {post.publishedAt && <p class="post-meta">{post.publishedAt}</p>}
          {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
          {post.youtubeUrl && (
            <p class="post-youtube">
              <a href={post.youtubeUrl} target="_blank" rel="noopener noreferrer">Ver en YouTube</a>
            </p>
          )}
        </div>
      </article>
    ))}
  </div>
  {totalPages > 1 && (
    <nav class="pagination" aria-label="Paginación del blog">
      {currentPage > 1 ? (
        <a class="pagination-link" href={prevHref}>Anterior</a>
      ) : (
        <span class="pagination-disabled">Inicio</span>
      )}
      <span class="pagination-current">Página {currentPage} de {totalPages}</span>
      {nextHref ? (
        <a class="pagination-link" href={nextHref}>Siguiente</a>
      ) : (
        <span class="pagination-disabled">Fin</span>
      )}
    </nav>
  )}
</section>
